<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QR Code Ranne Care</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<style>
body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#f5efe8;
    font-family:Arial, sans-serif;
}

.card{
    background:white;
    padding:30px;
    border-radius:35px;
    box-shadow:0 15px 40px rgba(0,0,0,0.08);
    text-align:center;
    width:420px;
    position:relative;
}

h1{
    color:#8b5e3c;
    margin-bottom:5px;
    font-size:38px;
    letter-spacing:2px;
}

.sub{
    color:#b88a68;
    margin-bottom:25px;
    font-size:16px;
}

.qr-wrapper{
    position:relative;
    width:320px;
    height:320px;
    margin:auto;
    background:white;
    padding:15px;
    border-radius:30px;
}

#qrcode{
    width:100%;
    height:100%;
}

.avatar{
    position:absolute;
    top:50%;
    left:50%;
    transform:translate(-50%, -50%);
    width:95px;
    height:95px;
    border-radius:50%;
    border:8px solid white;
    overflow:hidden;
    background:white;
    box-shadow:0 5px 15px rgba(0,0,0,0.15);
}

.avatar img{
    width:100%;
    height:100%;
    object-fit:cover;
}

.site{
    margin-top:25px;
    background:#d8a889;
    color:white;
    padding:14px;
    border-radius:20px;
    font-size:24px;
    font-weight:bold;
}

.footer{
    margin-top:18px;
    color:#9a755c;
    font-size:18px;
}
</style>
</head>
<body>

<div class="card">

    <h1>RANNE CARE</h1>
    <div class="sub">Cuidar é um ato de amor ♡</div>

    <div class="qr-wrapper">
        <div id="qrcode"></div>

        <div class="avatar">
            <img src="avatar.png" alt="Ranne">
        </div>
    </div>

    <div class="site">
        rannecare.com.br
    </div>

    <div class="footer">
        Escaneie e acesse nosso site
    </div>

</div>

<script>
new QRCode(document.getElementById("qrcode"), {
    text: "https://rannecare.com.br/",
    width: 320,
    height: 320,
    colorDark : "#000000",
    colorLight : "#ffffff",
    correctLevel : QRCode.CorrectLevel.H
});
</script>

</body>
</html>
